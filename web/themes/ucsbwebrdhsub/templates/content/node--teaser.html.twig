{#
/**
 * @file
 * Theme override to display a node teaser.
 *
 * This mirrors node--view-mode-teaser.html.twig and intentionally removes the
 * submitted metadata block in teaser/listing contexts.
 *
 * @ingroup templates
 */
#}
{%
  set classes = [
    node.bundle|clean_class,
    node.isPromoted() ? 'is-promoted',
    node.isSticky() ? 'is-sticky',
    not node.isPublished() ? 'is-unpublished',
    view_mode ? view_mode|clean_class,
    node.field_top_padding.value ? 'top-padding-' ~ node.field_top_padding.value,
    node.field_bottom_padding.value ? 'bottom-padding-' ~ node.field_bottom_padding.value,
    'clearfix',
  ]
%}
<article{{ attributes.addClass(classes).removeAttribute('role') }}>

  {{ title_prefix }}
  {% if not page %}
    <h2{{ title_attributes }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h2>
  {% endif %}
  {{ title_suffix }}

  {# Submitted metadata intentionally removed for teaser/listing contexts. #}

  <div{{ content_attributes.addClass('content') }}>
    {{ content }}
  </div>

</article>
